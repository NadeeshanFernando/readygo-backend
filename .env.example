# Copy this file to .env and fill in real values before running the server.
# NEVER commit the real .env file to git, and NEVER put these values in the
# React Native app — this backend is the only place they should exist.

# The master secret used to sign/verify every tag's HMAC. Generate a long
# random value, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TAG_SIGNING_SECRET=replace-this-with-a-long-random-value

# A separate secret used only to protect the /api/tags/provision endpoint
# (manufacturing-time tag creation) from being called by anyone but you.
ADMIN_API_KEY=replace-this-with-another-long-random-value

PORT=3000

# Optional — enables real LLM-generated AI Suggestions (Feature 6). Without
# this, /api/ai/suggestions still works but falls back to a small static
# baseline list. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
